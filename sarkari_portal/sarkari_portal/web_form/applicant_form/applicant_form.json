 "button_label": "Save",
 "client_script": "frappe.web_form.on('load', () => {\n    // 1. Sabse pehle QR code field ko hide kar dein (Background mein load rahega)\n    frappe.web_form.set_df_property('qr_code', 'hidden', 1);\n\n    // 2. Form se vacancy ka naam lein\n    let v_name = frappe.web_form.get_value('vacancy_name');\n\n    // Agar URL se vacancy_name aa raha hai (e.g. ?vacancy_name=GD Constable)\n    if (!v_name) {\n        const urlParams = new URLSearchParams(window.location.search);\n        v_name = urlParams.get('vacancy_name');\n    }\n\n    if (v_name) {\n        // 3. Database se QR Code image path fetch karke field mein bhar dein\n        frappe.call({\n            method: \"frappe.client.get_value\",\n            args: {\n                doctype: \"Government Vacancy\",\n                filters: { name: v_name }, // Yahan 'name' use kiya hai kyunki JSON mein name 'GD Constable' hai\n                fieldname: \"qr_code\"\n            },\n            callback: function(r) {\n                if (r.message && r.message.qr_code) {\n                    // QR path milte hi field mein set kar dein (User ko dikhega nahi kyunki hidden hai)\n                    frappe.web_form.set_value('qr_code', r.message.qr_code);\n                    console.log(\"QR Code loaded in background:\", r.message.qr_code);\n                }\n            }\n        });\n    }\n});\n\n// 4. Jab user 'Payment Started' checkbox par click kare\nfrappe.web_form.on('payment_started', (field, value) => {\n    if (value == 1) {\n        // Checkbox tick hone par QR code show karein\n        frappe.web_form.set_df_property('qr_code', 'hidden', 0);\n    } else {\n        // Un-tick hone par wapas hide karein\n        frappe.web_form.set_df_property('qr_code', 'hidden', 1);\n    }\n});",
